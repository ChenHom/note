# TiDB RAG Stack - template
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
RAG_API_PORT=8010
RAG_WORKER_PORT=8011

# Prefer service/container name when sharing a Docker network with TiDB
TIDB_HOST=tidb
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=rag

# Start with mock, then cut over to openai-compatible
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-384
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=384

QDRANT_COLLECTION=document_chunks
MINIO_BUCKET=documents
LOG_LEVEL=INFO
